# ============================================================
# BACKEND — ENV TEMPLATE (copy thành .env rồi điền giá trị)
# ============================================================

# ── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BE_HOST="http://localhost:3000"

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/quanlykho?schema=public"

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET="your-strong-random-secret-here"
JWT_EXPIRES_IN="24h"
DEFAULT_ADMIN_PASSWORD="change-me-in-production"

# ── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Logging ──────────────────────────────────────────────────
# LOG_LEVEL: error | warn | info | debug  (default: info)
LOG_LEVEL="info"

# ── File Storage ─────────────────────────────────────────────
# LOCAL  → lưu vào thư mục uploads/ trên disk (dùng cho local)
# CLOUDFLARE_R2 → upload lên R2 (cần điền R2_* bên dưới)
FILE_STORAGE_PROVIDER="LOCAL"

# ── Cloudflare R2 ────────────────────────────────────────────
# Để trống khi FILE_STORAGE_PROVIDER=LOCAL
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# ── Email ────────────────────────────────────────────────────
# Cách 1: Resend API (ưu tiên nếu RESEND_API_KEY có giá trị)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SMTP_FROM="onboarding@resend.dev"

# Cách 2: SMTP truyền thống — xoá RESEND_API_KEY để dùng cách này
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE="false"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="your-email@gmail.com"
