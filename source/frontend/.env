# ============================================================
# FRONTEND — LOCAL ENV (throwaway credentials, safe to commit)
# Secret thật (dev/prod) → quản lý qua Cloudflare Pages env vars
# ============================================================

# ── API Backend ──────────────────────────────────────────────
# URL gốc của Backend API (không có trailing slash, không có /api)
# Dev local: http://localhost:3000/api
# Dev cloud: https://your-app.fly.dev/api
# Production: https://api.3tgroup.com/api
VITE_API_URL="http://localhost:3000/api"

# ── Landing Page ─────────────────────────────────────────────
# URL của trang Landing Page (tư vấn khách hàng công khai)
# Dev: cùng origin với admin portal → dùng path tương đối
# Production: nếu deploy tách domain → đổi thành URL đầy đủ (https://3tgroup.com)
VITE_LANDING_PAGE_URL="/consulting"
